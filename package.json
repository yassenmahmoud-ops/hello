{
  "name": "multivendor-store-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:dev:css\" \"vite\"",
    "dev:css": "npx tailwindcss -i ./input.css -o ./output.css --watch",
    "build": "npx tailwindcss -i ./input.css -o ./output.css --minify && vite build",
    "preview": "vite preview",
    "format": "prettier --write \"**/*.{ts,js,html,css,json}\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "prettier": "^2.8.0"
  }
}
